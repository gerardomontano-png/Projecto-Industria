# ── Entornos virtuales ────────────────────────────────────────────────────────
env/
venv/
.venv/
.env/

# ── Variables de entorno (contienen secretos, nunca se suben) ─────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Distribución y empaquetado ────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Herramientas de testing y cobertura ───────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type checkers y linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Modelos entrenados y datasets (pueden ser muy pesados) ────────────────────
models/
*.pkl
*.h5
*.pt
*.pth
*.onnx
data/

# ── IDEs y editores ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
